# Copy to .env and fill in. Multiple keys are comma-separated; the key manager
# rotates through them with per-key cooldown on rate limits.

# Gemini (primary vision reader) -- get free keys at https://aistudio.google.com/apikey
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# Groq (reasoning + last-resort vision fallback; used from Phase 2) -- https://console.groq.com/keys
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2

# Secondary vision reader (google/gemini-2.5-flash via any OpenAI-compatible
# endpoint). Tried when the primary Gemini free-tier key is quota-blocked --
# recommended for a live demo. Set both to enable it; leave unset to skip it.
SECONDARY_VISION_KEY=your_secondary_vision_key
SECONDARY_VISION_BASE_URL=https://your-openai-compatible-endpoint/v1

# Demo safety: set to 1 to force offline mock extraction (no API calls).
KHATA_MOCK=0

# Optional overrides (defaults shown)
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# SECONDARY_VISION_MODEL=google/gemini-2.5-flash
# REVIEW_CONFIDENCE_THRESHOLD=0.8
