# Copy to .env and fill in. Multiple keys are comma-separated; the key manager
# rotates through them with per-key cooldown on rate limits.

# Gemini (vision) — get free keys at https://aistudio.google.com/apikey
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# Groq (reasoning; used from Phase 2) — https://console.groq.com/keys
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2

# Demo safety: set to 1 to force offline mock extraction (no API calls).
KHATA_MOCK=0

# Optional overrides (defaults shown)
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# REVIEW_CONFIDENCE_THRESHOLD=0.8
